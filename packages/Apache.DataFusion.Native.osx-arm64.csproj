<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <PackageId>Apache.DataFusion.Native.osx-arm64</PackageId>
    <Authors>Apache DataFusion</Authors>
    <Description>macOS arm64 native binaries for Apache.DataFusion.</Description>
    <PackageTags>datafusion;native;osx-arm64</PackageTags>
    <RepositoryUrl>https://github.com/apache/datafusion</RepositoryUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\native\target\aarch64-apple-darwin\release\libdatafusion_csharp_native.dylib" Pack="true"
		  PackagePath="runtimes\osx-arm64\native\libdatafusion_csharp_native.dylib" Visible="false" />
  </ItemGroup>

</Project>
